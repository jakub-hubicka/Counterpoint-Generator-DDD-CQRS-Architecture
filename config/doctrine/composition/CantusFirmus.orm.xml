<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Composition\Domain\Model\CantusFirmus" table="cantus_firmus">
        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <field name="compositionId" type="string" length="36" column="composition_id"/>
        <field name="tonicValue" type="string" length="2" column="tonic"/>
        <field name="notesData" type="json" column="notes_data"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>

        <lifecycle-callbacks>
            <lifecycle-callback type="postLoad" method="restoreMelodyFromData"/>
            <lifecycle-callback type="prePersist" method="syncMelodyToData"/>
            <lifecycle-callback type="preUpdate" method="syncMelodyToData"/>
        </lifecycle-callbacks>
    </entity>

</doctrine-mapping>
